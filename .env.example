# Port exposed on the Ubuntu host.
# Change this if 11434 is already occupied on your machine.
OLLAMA_PORT=11434

# Default model pulled by scripts/pull-model.sh when no interactive choice is made.
# Must be a valid model name from https://ollama.com/library
MODEL=gpt-oss:20b

# API key for accessing Ollama
OLLAMA_API_KEY=your-generated-key-here